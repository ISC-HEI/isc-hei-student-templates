#!/usr/bin/env bash

set -eu

# Packs a template into a package
# Adapted from https://github.com/johannes-wolf/cetz/blob/35c0868378cea5ad323cc0d9c2f76de8ed9ba5bd/scripts/package
# licensed under Apache License 2.0

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"; pwd -P)/.." # macOS 

TEMPLATE="$2"

if [[ -z "$TEMPLATE" ]]; then
  TEMPLATE="bachelor-thesis"
fi

if [[ ! -d "$ROOT/templates/$TEMPLATE" ]]; then
  echo "Template '$TEMPLATE' does not exist in '$ROOT/templates'."
  exit 1
fi

echo 
echo "Processing template $TEMPLATE"

. "$(dirname "${BASH_SOURCE[0]}")/setup" ${2}

TARGET="$(resolve-target "${1:?Missing target path, @local or @preview}")"
echo "Install dir: $TARGET"

# ignore rules
readarray -t ignores < <(grep -v '^#' .typstignore | grep '[^[:blank:]]')

# recursively print all files that are not excluded via .typstignore
function enumerate {
	local root="$1"
	if [[ -f "$root" ]]; then
		echo "$root"
	else
		local files
		readarray -t files < <(find "$root" \
      -mindepth 1 -maxdepth 1 \
      -not -name .git \
      -not -name .typstignore)
		# declare -p files >&2

		local f
		for f in "${files[@]}"; do
			local include
			include=1

			local ignore
			for ignore in "${ignores[@]}"; do
				if [[ "$ignore" =~ ^! ]]; then
					ignore="${ignore:1}"
					if [[ "$f" == ./$ignore ]]; then
						# echo "\"$f\" matched \"!$ignore\"" >&2
						include=1
					fi
				elif [[ "$f" == ./$ignore ]]; then
					# echo "\"$f\" matched \"$ignore\"" >&2
					include=0
				fi
			done
			if [[ "$include" == 1 ]]; then
				enumerate "$f"
			fi
		done
	fi
}

# List of all files that get packaged
readarray -t files < <(enumerate ".")
# declare -p files >&2

TMP="$(mktemp -d)"

for f in "${files[@]}"; do
  mkdir -p "$TMP/$(dirname "$f")" 2>/dev/null
  cp -r "$ROOT/$f" "$TMP/$f"  
done

# Copy the specific files in templates to the root directory
cp -a "$ROOT/templates/$TEMPLATE/README.md" "$TMP"
cp -a "$ROOT/templates/$TEMPLATE/typst.toml" "$TMP"

cp $ROOT/src/*.pdf "$ROOT/examples/" 2>/dev/null || true

# Verbose rm: print each file/dir actually removed
vrm() { for f in "$@"; do [[ -e "$f" ]] && echo "  Removing ${f#$TMP/}"; done; rm -rf "$@"; }

if [[ "$TEMPLATE" == "bachelor-thesis" ]]; then
	echo "Removing useless files from template $TEMPLATE"	
	vrm "$TMP/src/exec_summary.typ"
	vrm "$TMP/src/report.typ"
	vrm "$TMP/src/document.typ"
	vrm "$TMP/src/figs/random_image.png"	
	vrm "$TMP/src/figs/cover_image_placeholder.png"

	# other templates
	vrm "$TMP/src/tb_assignment.typ"
	vrm "$TMP/src/document.typ"
	vrm "$TMP/src/report.typ"	
	vrm "$TMP/src/exec_summary.typ"
	
	# thumbnails	
	vrm "$TMP/report_thumb.png"
	vrm "$TMP/exec_summary.png"
	vrm "$TMP/document_thumb.png"
	vrm "$TMP/tb_assignment_thumb.png"
fi

if [[ "$TEMPLATE" == "document" ]]; then
	echo "Removing useless files from template $TEMPLATE"
	vrm "$TMP/src/pages"
	vrm "$TMP/src/code"
	vrm "$TMP/src/check_result_file.sh"
	vrm "$TMP/src/figs/cover_image_placeholder.png"	

	# other templates
	vrm "$TMP/src/acronyms.typ"
	vrm "$TMP/src/bachelor_thesis.typ"	
	vrm "$TMP/src/tb_assignment.typ"
	vrm "$TMP/src/report.typ"	
	vrm "$TMP/src/exec_summary.typ"
	
	# thumbnails
	vrm "$TMP/bachelor_thesis_thumb.png"
	vrm "$TMP/report_thumb.png"
	vrm "$TMP/exec_summary.png"
	vrm "$TMP/tb_assignment_thumb.png"
fi

if [[ "$TEMPLATE" == "exec-summary" ]]; then
	echo "Removing useless files from template $TEMPLATE"
	vrm "$TMP/src/pages"
	vrm "$TMP/src/code"
	vrm "$TMP/src/check_result_file.sh"
	vrm "$TMP/src/report.typ"	
	vrm "$TMP/src/acronyms.typ"	
	vrm "$TMP/src/bachelor_thesis.typ"
	vrm "$TMP/src/tb_assignment.typ"
	vrm "$TMP/src/figs/cover_image_placeholder.png"	
	
	# other templates
	vrm "$TMP/src/bachelor_thesis.typ"	
	vrm "$TMP/src/tb_assignment.typ"
	vrm "$TMP/src/document.typ"
	vrm "$TMP/src/report.typ"	
	vrm "$TMP/src/bibliography.bib"

	# thumbnails
	vrm "$TMP/bachelor_thesis_thumb.png"
	vrm "$TMP/report_thumb.png"
	vrm "$TMP/document_thumb.png"
	vrm "$TMP/tb_assignment_thumb.png"
fi

if [[ "$TEMPLATE" == "report" ]]; then
	# remove the typst.toml in the template directory
	echo "Removing useless files from template $TEMPLATE"	
	vrm "$TMP/src/check_result_file.sh"
	vrm "$TMP/src/bachelor_thesis.typ"
	vrm "$TMP/src/tb_assignment.typ"
	vrm "$TMP/src/exec_summary.typ"
	vrm "$TMP/src/figs/random_image.png"
	vrm "$TMP/src/figs/made.svg"
	vrm "$TMP/src/pages"

	# other templates
	vrm "$TMP/src/bachelor_thesis.typ"	
	vrm "$TMP/src/tb_assignment.typ"
	vrm "$TMP/src/document.typ"
	vrm "$TMP/src/exec_summary.typ"
	
	# thumbnails
	vrm "$TMP/bachelor_thesis_thumb.png"
	vrm "$TMP/exec_summary.png"
	vrm "$TMP/document_thumb.png"
	vrm "$TMP/tb_assignment_thumb.png"
fi

if [[ "$TEMPLATE" == "tb-assignment" ]]; then
	# remove the typst.toml in the template directory
	echo "Removing useless files from template $TEMPLATE"	
	vrm "$TMP/src/check_result_file.sh"
	vrm "$TMP/src/exec_summary.typ"
	vrm "$TMP/src/figs"
	vrm "$TMP/src/code"
	vrm "$TMP/src/themes"
	vrm "$TMP/src/pages"

	# other templates
	vrm "$TMP/src/acronyms.typ"	
	vrm "$TMP/src/bachelor_thesis.typ"	
	vrm "$TMP/src/document.typ"
	vrm "$TMP/src/report.typ"	
	vrm "$TMP/src/exec_summary.typ"
	vrm "$TMP/src/bibliography.bib"

	# thumbnails
	vrm "$TMP/bachelor_thesis_thumb.png"
	vrm "$TMP/report_thumb.png"
	vrm "$TMP/exec_summary.png"
	vrm "$TMP/document_thumb.png"
fi

TARGET="${TARGET:?}/${PKG_PREFIX:?}/${VERSION:?}"
echo "Packaged to: $TARGET"

if rm -r "${TARGET:?}" 2>/dev/null; then
  echo "Overwriting existing version."
fi
mkdir -p "$TARGET"

# include hidden files by setting dotglob
shopt -s dotglob

mv "$TMP"/* "$TARGET"